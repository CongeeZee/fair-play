generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                Int              @id @default(autoincrement())
  email             String           @unique
  passwordHash      String?
  googleId          String?          @unique
  name              String
  emailVerified     Boolean          @default(false)
  verificationToken String?          @unique
  createdAt         DateTime         @default(now())
  rounds            Round[]
  refreshTokens     RefreshToken[]
  linkedHandicap    LinkedHandicap?
  sentRequests      Friendship[]     @relation("requester")
  receivedRequests  Friendship[]     @relation("addressee")
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  BLOCKED
}

model Friendship {
  id          String           @id @default(uuid())
  requesterId Int
  addresseeId Int
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  requester   User             @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  addressee   User             @relation("addressee", fields: [addresseeId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
}

model LinkedHandicap {
  id             Int      @id @default(autoincrement())
  userId         Int      @unique
  source         String   // "golf_australia", "ghin", "manual"
  externalId     String?  // GolfLink number, GHIN number, etc.
  handicapIndex  Float
  playerName     String?  // Name returned from lookup
  clubName       String?  // Club returned from lookup
  lastSynced     DateTime @default(now())
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id           Int     @id @default(autoincrement())
  name         String
  externalId   String? @unique
  courseRating Float?
  slopeRating  Int?
  holes        Hole[]
  rounds       Round[]
}

model Hole {
  id             Int         @id @default(autoincrement())
  number         Int
  par            Int
  distance       Int
  courseId        Int
  greenLatitude  Float?
  greenLongitude Float?
  course         Course      @relation(fields: [courseId], references: [id])
  scores         RoundHole[]

  @@unique([courseId, number])
}

model Round {
  id         Int         @id @default(autoincrement())
  shareId    String?     @unique
  playedAt   DateTime    @default(now())
  userId     Int
  courseId   Int
  user       User        @relation(fields: [userId], references: [id])
  course     Course      @relation(fields: [courseId], references: [id])
  roundHoles RoundHole[]
}

model RoundHole {
  id               Int     @id @default(autoincrement())
  roundId          Int
  holeId           Int
  strokes          Int
  putts            Int?
  teeShotDirection String?
  teeShotDistance  String?
  approachResult   String?
  sandShots        Int?
  penalties        Int?
  hazards          Int?
  round            Round   @relation(fields: [roundId], references: [id], onDelete: Cascade)
  hole             Hole    @relation(fields: [holeId], references: [id])

  @@unique([roundId, holeId])
}
