generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  rounds       Round[]
}

model Course {
  id           Int     @id @default(autoincrement())
  name         String
  externalId   String? @unique
  courseRating Float?
  slopeRating  Int?
  holes        Hole[]
  rounds       Round[]
}

model Hole {
  id        Int         @id @default(autoincrement())
  number    Int
  par       Int
  distance  Int
  courseId  Int
  course    Course      @relation(fields: [courseId], references: [id])
  scores    RoundHole[]

  @@unique([courseId, number])
}

model Round {
  id         Int         @id @default(autoincrement())
  playedAt   DateTime    @default(now())
  userId     Int
  courseId   Int
  user       User        @relation(fields: [userId], references: [id])
  course     Course      @relation(fields: [courseId], references: [id])
  roundHoles RoundHole[]
}

model RoundHole {
  id               Int     @id @default(autoincrement())
  roundId          Int
  holeId           Int
  strokes          Int
  putts            Int?
  teeShotDirection String?
  sandShots        Int?
  penalties        Int?
  hazards          Int?
  round            Round   @relation(fields: [roundId], references: [id], onDelete: Cascade)
  hole             Hole    @relation(fields: [holeId], references: [id])

  @@unique([roundId, holeId])
}
