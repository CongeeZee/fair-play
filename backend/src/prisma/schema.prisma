generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model Course {
  id        Int @id @default(autoincrement())
  name      String
  distance  Int
  holes     Hole[]
}

model Hole {
  id        Int @id @default(autoincrement())
  number    Int
  par       Int
  distance  Int
  courseId  Int
  course    Course @relation(fields: [courseId], references: [id])
}

